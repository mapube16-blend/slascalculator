# Configuración de PostgreSQL (Zammad Database)
DB_HOST=your-database-host.region.rds.amazonaws.com
DB_PORT=5432
DB_NAME=postgres
DB_USER=your-database-user
DB_PASSWORD=your-secure-password

# Puerto del servidor
PORT=3000

# Configuración de zona horaria
TIMEZONE=America/Mexico_City

# CORS - Dominios permitidos (separar con coma si son varios)
# Ejemplo: https://d1234abcd.cloudfront.net,https://mi-dominio.com
CORS_ORIGIN=*

# Servir frontend desde Express (poner "false" si el frontend está en S3)
SERVE_FRONTEND=true

# ============================================================
# AWS - Pipeline de datos para QuickSight
# (Solo necesario si se usa el pipeline S3 → Glue → QuickSight)
# ============================================================

# Bucket S3 donde se guardan los Parquet exportados por el CRON
# Se obtiene del output de CloudFormation: ./aws/deploy-infra.sh --outputs
AWS_S3_BUCKET=

# Prefijo S3 (no cambiar a menos que se modifique el CloudFormation)
AWS_S3_PREFIX=sla-data

# Region AWS
AWS_REGION=us-east-1

# Nombre del Glue Crawler (se activa automaticamente despues de subir archivos)
# Se obtiene del output de CloudFormation: ./aws/deploy-infra.sh --outputs
AWS_GLUE_CRAWLER_NAME=

# Instrucciones:
# 1. Copia este archivo como .env
# 2. Reemplaza los valores de ejemplo con tus credenciales reales
# 3. NUNCA commitees el archivo .env a git
# 4. Para el pipeline AWS, ejecutar primero: ./aws/deploy-infra.sh
